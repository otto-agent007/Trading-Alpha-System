# ── LLM ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-your-key-here
HEAVY_MODEL=anthropic/claude-opus-4-6
LIGHT_MODEL=qwen3.5:4b
OLLAMA_HOST=http://localhost:11434

# ── Embeddings (optional — Gemini Embedding for semantic memory) ──────────────
# GOOGLE_API_KEY=your-google-api-key

# ── Platform API keys (optional for reads, required for live trading) ─────────
# KALSHI_API_KEY=your-kalshi-key
# KALSHI_API_SECRET=your-kalshi-secret

# ── Paths ─────────────────────────────────────────────────────────────────────
# Windows example — adjust to your machine:
OBSIDIAN_VAULT=C:\path\to\your\ObsidianVault\VaultName
MEMORY_PATH=C:\path\to\.trading-alpha\memory
DATA_PATH=C:\path\to\.trading-alpha\data
# Linux/Docker example:
# OBSIDIAN_VAULT=/app/obsidian_vault
# MEMORY_PATH=/app/memory
# DATA_PATH=/app/data

# ── Trading ───────────────────────────────────────────────────────────────────
PAPER_MODE=true
INITIAL_BANKROLL=1000
MAX_POSITION_PCT=0.05

# ── Schedule ──────────────────────────────────────────────────────────────────
SCAN_INTERVAL_HOURS=2
ANALYSIS_INTERVAL_HOURS=4
REVIEW_HOUR_UTC=3

# ── Auto-discovery keywords (comma-separated, scanner flags matches) ──────────
WATCH_KEYWORDS=BTC 5-Minute,BTC 15-Minute,NBA
